generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Reservation {
  id           String    @id @default(cuid())
  source       String    // "naver", "spacecloud", "manual"
  roomName     String    @default("머무룸1")
  customerName String?
  phone        String?
  startTime    DateTime
  endTime      DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  notified     Boolean   @default(false) // 예약 2시간 전 알림 발송 여부
  price        Int       @default(0)     // 최종 매출액 (쿠폰 할인 적용 후)
  discount     Int       @default(0)     // 사용한 쿠폰/할인 금액 (원가 - 최종가)
  status       String    @default("CONFIRMED") // "CONFIRMED" | "CANCELLED"
  paymentMethod String?  @default("온라인")     // "현장카드" | "계좌이체" | "온라인"
  isPaid        Boolean  @default(true)         // 결제 완료 여부 (이체 등 미결제는 false)
  emailId      String?   @unique

  usageLog     UsageLog?
}

model UsageLog {
  id            String      @id @default(cuid())
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  headCount         Int     @default(0)   // 실제 이용인원 (CCTV 관찰 기준, 분석의 기준값)
  reservedHeadCount Int     @default(0)   // 예약 이용인원 (메일 자동, 플랫폼 최소인원 영향)
  coffeeCount   Int         @default(0)
  purpose       String?     // 대분류(고정): 교육/보드게임/사적모임/촬영/회사회의/기타 (null=미입력)
  detail        String?     // 세부내용(자유입력): "보험교육", "유튜브 촬영" 등
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
